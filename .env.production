# 生产环境配置
VITE_WEB_ENV = 'production'

# 生产环境
VITE_WEB_BASE_API = '/prod-api'

# 是否在打包时开启压缩，支持 gzip 和 brotli
VITE_BUILD_COMPRESS = gzip

# 通过 nginx 代理，使用相对路径
VITE_API_URL = '/prod-api'

